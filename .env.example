# Reenvío de leads (demo gratis + reporte IA) hacia pos_tracking_api, para que
# aparezcan en el mismo dashboard de leads que usa Centro de Control (POS).
# TRACKING_API_SERVICE_TOKEN debe ser IGUAL al valor de SERVICE_TOKEN configurado
# en pos_tracking_api/.env — pídeselo a quien administre ese servicio, no lo
# inventes aquí.
TRACKING_API_URL=
TRACKING_API_SERVICE_TOKEN=
